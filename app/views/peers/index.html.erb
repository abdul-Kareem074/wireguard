<h1>Peers</h1>

<%= link_to 'New Peer', new_peer_path, class: 'btn' %>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Server</th>
      <th>User</th>
      <th>Allowed IPs</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @peers.each do |peer| %>
      <tr>
        <td><%= peer.name %></td>
        <td><%= peer.vpn_server.name %></td>
        <td><%= peer.user.email %></td>
        <td><%= peer.allowed_ips %></td>
        <td>
          <%= link_to 'Show', peer, class: 'btn' %>
          <%= link_to 'Edit', edit_peer_path(peer), class: 'btn' %>
          <%= link_to 'Destroy', peer, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-danger' %>
          <%= link_to 'Generate Keys', generate_keys_peer_path(peer), class: 'btn' %>
          <%= link_to 'Download Config', download_config_peer_path(peer), class: 'btn' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>