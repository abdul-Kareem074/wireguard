<h1><%= @peer.name %></h1>

<p>
  <strong>Name:</strong>
  <%= @peer.name %>
</p>

<p>
  <strong>VPN Server:</strong>
  <%= @peer.vpn_server.name %>
</p>

<p>
  <strong>User:</strong>
  <%= @peer.user.email %>
</p>

<p>
  <strong>Public Key:</strong>
  <%= @peer.public_key %>
</p>

<p>
  <strong>Allowed IPs:</strong>
  <%= @peer.allowed_ips %>
</p>

<%= link_to 'Edit', edit_peer_path(@peer), class: 'btn' %> |
<%= link_to 'Generate Keys', generate_keys_peer_path(@peer), class: 'btn' %> |
<%= link_to 'Download Config', download_config_peer_path(@peer), class: 'btn' %> |
<%= link_to 'Back', peers_path, class: 'btn' %>